const int touchPin = 2;
const int ledPin = 9;

int brightness = 0;

void setup() {
  pinMode(touchPin, INPUT);
  pinMode(ledPin, OUTPUT);
}

void loop() {

  if (digitalRead(touchPin) == HIGH) {

    brightness = brightness + 51;

    if (brightness > 255) {
      brightness = 0;
    }

    analogWrite(ledPin, brightness);

    delay(300);
  }
}
